    {
      "#": "Test data — this whole provider is ignored because its id starts with '#'.",
      "id": "#example",
      "name": "#Example provider (ignored)",
      "mode": "openai",
      "baseUrl": "https://example.com/v1/chat/completions",
      "models": [
        { "id": "real-model", "name": "Kept" },
        { "#id": "commented-out-model", "name": "#ignored" }
      ]
    }
  ]
}
