    {
      "id": "moonshot",
      "name": "Moonshot (Kimi)",
      "mode": "openai",
      "baseUrl": "https://api.moonshot.ai/v1/chat/completions",
      "keyEnv": "MOONSHOT_API_KEY",
      "keyUrl": "https://platform.moonshot.ai/console/api-keys",
      "models": [
